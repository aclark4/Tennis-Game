[sub_resource type="GDScript" id="GDScript_iacmt"]
script/source = "extends Node2D


@onready var player: CharacterBody2D = $Player

var inventory_scene = preload(\"res://Scenes/inventory.tscn\")
var near_counter: bool = false
var inventory_open: bool = false


# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	player.position = GameData.player_position


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	if inventory_open:
		return
	if near_counter and Input.is_action_just_pressed(\"Interact\"):
		GameData.player_position = player.position
		if GameData.customer_queue.size() > 0:
			var front = GameData.customer_queue[0]
			if front.state == front.CustomerState.WAITING:
				front.state = front.CustomerState.BEING_SERVED
		open_inventory()



func open_inventory() -> void:
	inventory_open = true
	var overlay = CanvasLayer.new()
	var inventory = inventory_scene.instantiate()
	add_child(overlay)
	overlay.add_child(inventory)
	player.set_physics_process(false) # Freezes the player
	inventory.closed.connect(func():
		inventory_open = false
		player.set_physics_process(true)
		overlay.queue_free()
	)

# Handles when the character is behind the counter
func _on_counter_zone_body_entered(body: Node2D) -> void:
	if body == player:
		near_counter = true
		print(\"behind counterd\")

func _on_counter_zone_body_exited(body: Node2D) -> void:
	if body == player:
		near_counter = false
"

